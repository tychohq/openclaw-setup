# Copy to .env and fill in your values.
# The setup wizard reads these so you don't have to type them every time.
# .env is gitignored — never committed.

# ── Deployment ────────────────────────────────────────────────
DEPLOYMENT_NAME="my-openclaw"
INSTANCE_NAME=""                    # Override EC2 Name tag (default: DEPLOYMENT_NAME-instance)
OWNER_NAME="Your Name"
TIMEZONE="America/New_York"
AWS_REGION="us-east-1"                # Also sets Bedrock API endpoint region

# ── Existing Infrastructure (optional) ────────────────────────
# Deploy into an existing VPC instead of creating a new one.
# If set, Terraform skips VPC/subnet/IGW creation.
# EXISTING_VPC_ID=""
# EXISTING_SUBNET_ID=""
# EXISTING_SECURITY_GROUP_ID=""

# ── LLM Provider (at least one required) ─────────────────────
ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# AWS_BEARER_TOKEN_BEDROCK=""         # Bedrock bearer token (ABSK...) — requires AWS_REGION to be set

# ── Slack (recommended for teams) ────────────────────────────
# Create app at https://api.slack.com/apps → "From scratch"
# Enable Socket Mode → create App Token (xapp-...) with connections:write
# Install to workspace → copy Bot Token (xoxb-...)
# Subscribe to bot events: app_mention, message.channels, message.groups,
#   message.im, message.mpim, reaction_added, reaction_removed
# See: https://docs.openclaw.ai/channels/slack
SLACK_APP_TOKEN=""
SLACK_BOT_TOKEN=""
SLACK_OWNER_USER_ID=""              # Your Slack member ID (Profile → ⋮ → Copy member ID)
# SLACK_CHANNEL_ID=""

# ── Discord (optional) ──────────────────────────────────────
# DISCORD_TOKEN=""                   # (was DISCORD_BOT_TOKEN in older configs)
# DISCORD_GUILD_ID=""
# DISCORD_CHANNEL_ID=""
# DISCORD_OWNER_ID=""

# ── Telegram (optional) ─────────────────────────────────────
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_OWNER_ID=""

# ── Gateway ───────────────────────────────────────────────────
# Auto-generated by the wizard if not set. Maps to OPENCLAW_GATEWAY_TOKEN
# in the canonical shared/config/openclaw-env.template.
# GATEWAY_AUTH_TOKEN=""

# ── First-Boot Onboarding ────────────────────────────────────
# When true, the bot messages you on first interaction to pick
# a persona from righthands.dev and optionally connect Google.
# ENABLE_FIRST_BOOT="true"

# ── Google Workspace (GOG CLI) ───────────────────────────────
# Path to Google OAuth credentials.json (from Google Cloud Console)
# After deploy, authorize via: gog auth add user@domain.com --remote --readonly
# GOOGLE_OAUTH_CREDENTIALS_FILE=""

# GOG_KEYRING_PASSWORD is auto-generated during deploy (for headless keyring).
# Only set manually if you need to pre-configure it.
# GOG_KEYRING_PASSWORD=""

# ── Terraform State Backend ──────────────────────────────────
# Store Terraform state in S3 (recommended). Set to "false" for local state.
# Bucket: {owner-name}-{assistant-name}-tfstate (e.g. brenner-spear-axel-tfstate)
# DynamoDB lock table: {bucket-name}-lock
TFSTATE_S3="true"
