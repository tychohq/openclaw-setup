# terraform.tfvars — Pre-configured OpenClaw deployment.
# Copy to terraform.tfvars and verify all file() paths exist.
# NEVER commit terraform.tfvars — it is gitignored.
#
# Expected directory layout (monorepo):
#
#   openclaw-setup/
#   ├── openclaw-secrets.json                 # Fill in from shared/config/openclaw-config.template.json
#   ├── openclaw-secrets.env                  # Fill in from shared/config/openclaw-env.template
#   ├── openclaw-auth-profiles.json           # Fill in from shared/config/openclaw-auth-profiles.template.json
#   ├── shared/
#   │   ├── workspace/                        # Workspace files (SOUL.md, USER.md, docs/, tools/, ...)
#   │   ├── skills/                           # Custom skills (clawdstrike/, email/, ...)
#   │   ├── cron-jobs/                        # Cron job JSON specs
#   │   └── config/                           # Config templates
#   └── aws/
#       └── terraform/
#           └── terraform.tfvars              # ← you are here
#
# All file() paths are relative to the terraform/ directory.

aws_region  = "us-east-1"
environment = "prod"

# ── Instance ───────────────────────────────────────────────────────────────────

instance_type   = "t4g.medium"
ebs_volume_size = 30

# ── Owner ──────────────────────────────────────────────────────────────────────

owner_name = "Your Name"
timezone   = "America/New_York"

# ── OpenClaw Config ────────────────────────────────────────────────────────────
#
# Fill in the template files from shared/config/ and save them to the
# repo root. They are gitignored and never committed.
#
#   config/openclaw-config.template.json        → openclaw-secrets.json
#   config/openclaw-env.template                → openclaw-secrets.env
#   config/openclaw-auth-profiles.template.json → openclaw-auth-profiles.json

openclaw_config_json        = file("../openclaw-secrets.json")
openclaw_env                = file("../openclaw-secrets.env")
openclaw_auth_profiles_json = file("../openclaw-auth-profiles.json")

# ── Google Workspace (GOG CLI) ─────────────────────────────────────────────────
google_oauth_credentials_json = file("../google-credentials.json")

# ── Workspace Seed Files ───────────────────────────────────────────────────────
#
# Written to /home/openclaw/.openclaw/workspace/ on the instance.
# Parent directories are created automatically.

workspace_files = {
  # Root-level identity/config files
  "SOUL.md"     = file("../../shared/workspace/SOUL.md")
  "USER.md"     = file("../../shared/workspace/USER.md")
  "AGENTS.md"   = file("../../shared/workspace/AGENTS.md")
  "IDENTITY.md" = file("../../shared/workspace/IDENTITY.md")
  "TOOLS.md"    = file("../../shared/workspace/TOOLS.md")
  "MEMORY.md"   = file("../../shared/workspace/MEMORY.md")

  # docs/
  "docs/openclaw-playbook.md" = file("../../shared/workspace/docs/openclaw-playbook.md")
  "docs/doc-layers.md"        = file("../../shared/workspace/docs/doc-layers.md")

  # tools/
  "tools/browser.md"       = file("../../shared/workspace/tools/browser.md")
  "tools/discord.md"       = file("../../shared/workspace/tools/discord.md")
  "tools/docker.md"        = file("../../shared/workspace/tools/docker.md")
  "tools/pdf.md"           = file("../../shared/workspace/tools/pdf.md")
  "tools/uv-python.md"     = file("../../shared/workspace/tools/uv-python.md")
  "tools/async-polling.md" = file("../../shared/workspace/tools/async-polling.md")

  # scripts/
  "scripts/error-digest.sh"      = file("../../shared/workspace/scripts/error-digest.sh")
  "scripts/md2pdf.sh"             = file("../../shared/workspace/scripts/md2pdf.sh")
  "scripts/pre-commit-secrets.sh" = file("../../shared/workspace/scripts/pre-commit-secrets.sh")

  # bootstrap/
  "bootstrap/discord-setup.md" = file("../../shared/workspace/bootstrap/discord-setup.md")
  "bootstrap/README.md"        = file("../../shared/workspace/bootstrap/README.md")
  "bootstrap/secrets-guide.md" = file("../../shared/workspace/bootstrap/secrets-guide.md")
  "bootstrap/setup-context.md" = file("../../shared/workspace/bootstrap/setup-context.md")
  "bootstrap/TODO.md"          = file("../../shared/workspace/bootstrap/TODO.md")
}

