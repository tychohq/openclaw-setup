    "references/supply-chain.md"            = file("../../shared/skills/clawdstrike/references/supply-chain.md")
    "references/threat-model.md"            = file("../../shared/skills/clawdstrike/references/threat-model.md")
    "references/tools.md"                   = file("../../shared/skills/clawdstrike/references/tools.md")
    "references/verified-allowlist.md"      = file("../../shared/skills/clawdstrike/references/verified-allowlist.md")
    "references/version-risk.md"            = file("../../shared/skills/clawdstrike/references/version-risk.md")
    "scripts/collect_verified.sh"           = file("../../shared/skills/clawdstrike/scripts/collect_verified.sh")
    "scripts/config_summary.py"             = file("../../shared/skills/clawdstrike/scripts/config_summary.py")
