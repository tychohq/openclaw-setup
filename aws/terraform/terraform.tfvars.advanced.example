  "system-watchdog" = {
    "SKILL.md"  = file("../../shared/skills/system-watchdog/SKILL.md")
    "check.sh"  = file("../../shared/skills/system-watchdog/check.sh")
  }
}

# ── Cron Jobs ──────────────────────────────────────────────────────────────────
#
# Written to /home/openclaw/.openclaw/workspace/cron-jobs/<name>.json.
# After deploy, ask OpenClaw to register them:
#   "Please register the cron jobs in ~/.openclaw/workspace/cron-jobs/"

cron_jobs = {
  "self-reflection"       = file("../../shared/cron-jobs/self-reflection.json")
  "system-watchdog"       = file("../../shared/cron-jobs/system-watchdog.json")
  "daily-workspace-commit" = file("../../shared/cron-jobs/daily-workspace-commit.json")
  "error-log-digest"      = file("../../shared/cron-jobs/error-log-digest.json")
  "cron-health-watchdog"  = file("../../shared/cron-jobs/cron-health-watchdog.json")
}

# ── Skills ─────────────────────────────────────────────────────────────────────
#
# clawhub skills pre-installed at boot via `clawhub install <skill>`.
# Match this list to bootstrap-openclaw-workspace.sh in shared/scripts/.

clawhub_skills = [
  "agent-browser",
  "architecture-research",
  "caddy",
  "commit",
  "create-mcp",
  "deslop",
  "dev-serve",
  "diagrams",
  "domain-check",
