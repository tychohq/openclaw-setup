    "references/channels.md"                = file("../../shared/skills/clawdstrike/references/channels.md")
    "references/config-keys.md"             = file("../../shared/skills/clawdstrike/references/config-keys.md")
    "references/discovery.md"               = file("../../shared/skills/clawdstrike/references/discovery.md")
    "references/evidence-template.md"       = file("../../shared/skills/clawdstrike/references/evidence-template.md")
    "references/filesystem.md"              = file("../../shared/skills/clawdstrike/references/filesystem.md")
    "references/gateway.md"                 = file("../../shared/skills/clawdstrike/references/gateway.md")
    "references/network.md"                 = file("../../shared/skills/clawdstrike/references/network.md")
    "references/redaction.md"               = file("../../shared/skills/clawdstrike/references/redaction.md")
