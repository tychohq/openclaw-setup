  }

  "self-reflection" = {
    "SKILL.md"                      = file("../../shared/skills/self-reflection/SKILL.md")
    "scripts/summarize-sessions.sh" = file("../../shared/skills/self-reflection/scripts/summarize-sessions.sh")
