#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PATCH_SCRIPT_DEFAULT="$REPO_ROOT/shared/patches/scripts/openclaw-patch"

EXIT_SUCCESS=0
EXIT_FAILURE=1
EXIT_LOCK=2
EXIT_ROLLBACK=3
EXIT_HEALTH=4

OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
CONFIG_FILE="$OPENCLAW_HOME/openclaw-upgrade.env"

CHANNEL="stable"
TAG=""
TIMEOUT="1200"
HEALTH_TIMEOUT="180"
HEALTH_INTERVAL="5"
MODE="apply"
RETAIN_COUNT="10"
RETAIN_DAYS="30"
DISK_THRESHOLD_MB="200"
WEBHOOK_URL=""
NOTIFY=false
NOTIFY_CHANNEL=""
NOTIFY_TARGET=""
DEPLOYMENT=""
WITH_PATCHES=false
DRY_RUN=false
PLATFORM_OVERRIDE="${OPENCLAW_UPGRADE_PLATFORM:-}"

TIMESTAMP=""
START_EPOCH="0"
LOG_DIR=""
BACKUPS_DIR=""
LOG_PATH=""
BACKUP_DIR=""
LOCK_FILE=""
LOCK_ACQUIRED=false
PLATFORM=""
SERVICE_LABEL=""
SERVICE_UNIT=""
PATCH_STATUS="skipped"
FINAL_STATUS="failure"
FINAL_EXIT_CODE="$EXIT_FAILURE"
FAILURE_REASON=""

GATEWAY_STATUS_BEFORE_JSON=""
UPDATE_STATUS_BEFORE_JSON=""
UPDATE_PREVIEW_JSON=""
UPDATE_RESULT_JSON=""
HEALTH_JSON=""
CRON_BEFORE_JSON=""
CRON_STATUS_BEFORE_JSON=""
SKILLS_BEFORE_JSON=""
CRON_AFTER_JSON=""
CRON_STATUS_AFTER_JSON=""
SKILLS_AFTER_JSON=""

INSTALL_KIND=""
UPDATE_ROOT=""
PREVIOUS_VERSION=""
PREVIOUS_GIT_SHA=""
FINAL_VERSION=""

usage() {
  cat <<'USAGE'
Usage: openclaw-upgrade [options]

Options:
  --channel <stable|beta|dev>
  --tag <dist-tag|version>
  --timeout <seconds>
  --health-timeout <seconds>
  --health-interval <seconds>
  --mode <apply|notify-only>
  --retain-count <n>
  --retain-days <n>
  --disk-threshold-mb <n>
  --deployment <name>
  --webhook <url>
  --notify
  --notify-channel <channel>
  --notify-target <target>
  --with-patches
  --dry-run
  --help
USAGE
}

log() { printf '[openclaw-upgrade] %s\n' "$*"; }
warn() { printf '[openclaw-upgrade] WARN: %s\n' "$*" >&2; }
fail() { printf '[openclaw-upgrade] ERROR: %s\n' "$*" >&2; }

shell_join() {
  local out=() arg
  for arg in "$@"; do
    out+=("$(printf '%q' "$arg")")
  done
  printf '%s ' "${out[@]}"
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { fail "Required command not found: $1"; return 1; }
}

json_get() {
  local input="$1" filter="$2"
  printf '%s' "$input" | jq -r "$filter // empty" 2>/dev/null || true
}

run_capture_stdout() {
  local stdout_file stderr_file rc
  stdout_file="$(mktemp "${TMPDIR:-/tmp}/openclaw-upgrade.stdout.XXXXXX")"
  stderr_file="$(mktemp "${TMPDIR:-/tmp}/openclaw-upgrade.stderr.XXXXXX")"

  if "$@" >"$stdout_file" 2>"$stderr_file"; then
    rc=0
  else
    rc=$?
  fi

  [[ -s "$stderr_file" ]] && cat "$stderr_file" >&2
  [[ -s "$stdout_file" ]] && cat "$stdout_file"
  rm -f "$stdout_file" "$stderr_file"
  return "$rc"
}

run_logged() {
  log "Running: $(shell_join "$@")"
  "$@"
}

load_config_file() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi

  CHANNEL="${OPENCLAW_UPGRADE_CHANNEL:-$CHANNEL}"
  TAG="${OPENCLAW_UPGRADE_TAG:-$TAG}"
  TIMEOUT="${OPENCLAW_UPGRADE_TIMEOUT:-$TIMEOUT}"
  HEALTH_TIMEOUT="${OPENCLAW_UPGRADE_HEALTH_TIMEOUT:-$HEALTH_TIMEOUT}"
  HEALTH_INTERVAL="${OPENCLAW_UPGRADE_HEALTH_INTERVAL:-$HEALTH_INTERVAL}"
  MODE="${OPENCLAW_UPGRADE_MODE:-$MODE}"
  RETAIN_COUNT="${OPENCLAW_UPGRADE_RETAIN_COUNT:-$RETAIN_COUNT}"
  RETAIN_DAYS="${OPENCLAW_UPGRADE_RETAIN_DAYS:-$RETAIN_DAYS}"
  DISK_THRESHOLD_MB="${OPENCLAW_UPGRADE_DISK_THRESHOLD_MB:-$DISK_THRESHOLD_MB}"
  WEBHOOK_URL="${OPENCLAW_UPGRADE_WEBHOOK:-$WEBHOOK_URL}"
  NOTIFY_CHANNEL="${OPENCLAW_UPGRADE_NOTIFY_CHANNEL:-$NOTIFY_CHANNEL}"
  NOTIFY_TARGET="${OPENCLAW_UPGRADE_NOTIFY_TARGET:-$NOTIFY_TARGET}"
  DEPLOYMENT="${OPENCLAW_UPGRADE_DEPLOYMENT:-$DEPLOYMENT}"
  if [[ "${OPENCLAW_UPGRADE_WITH_PATCHES:-}" == "true" ]]; then
    WITH_PATCHES=true
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --channel) shift; CHANNEL="${1:-}" ;;
      --tag) shift; TAG="${1:-}" ;;
      --timeout) shift; TIMEOUT="${1:-}" ;;
      --health-timeout) shift; HEALTH_TIMEOUT="${1:-}" ;;
      --health-interval) shift; HEALTH_INTERVAL="${1:-}" ;;
      --mode) shift; MODE="${1:-}" ;;
      --retain-count) shift; RETAIN_COUNT="${1:-}" ;;
      --retain-days) shift; RETAIN_DAYS="${1:-}" ;;
      --disk-threshold-mb) shift; DISK_THRESHOLD_MB="${1:-}" ;;
      --deployment) shift; DEPLOYMENT="${1:-}" ;;
      --webhook) shift; WEBHOOK_URL="${1:-}" ;;
      --notify) NOTIFY=true ;;
      --notify-channel) shift; NOTIFY_CHANNEL="${1:-}" ;;
      --notify-target) shift; NOTIFY_TARGET="${1:-}" ;;
      --with-patches) WITH_PATCHES=true ;;
      --dry-run) DRY_RUN=true ;;
      --help|-h) usage; return 1 ;;
      *) fail "Unknown argument: $1"; usage >&2; return 2 ;;
    esac
    shift || true
  done
}

validate_args() {
  case "$CHANNEL" in stable|beta|dev) ;; *) fail "--channel must be stable, beta, or dev"; return 1 ;; esac
  case "$MODE" in apply|notify-only) ;; *) fail "--mode must be apply or notify-only"; return 1 ;; esac
  case "$TIMEOUT" in ''|*[!0-9]*) fail "--timeout must be an integer"; return 1 ;; esac
  case "$HEALTH_TIMEOUT" in ''|*[!0-9]*) fail "--health-timeout must be an integer"; return 1 ;; esac
  case "$HEALTH_INTERVAL" in ''|*[!0-9]*) fail "--health-interval must be an integer"; return 1 ;; esac
  case "$RETAIN_COUNT" in ''|*[!0-9]*) fail "--retain-count must be an integer"; return 1 ;; esac
  case "$RETAIN_DAYS" in ''|*[!0-9]*) fail "--retain-days must be an integer"; return 1 ;; esac
  case "$DISK_THRESHOLD_MB" in ''|*[!0-9]*) fail "--disk-threshold-mb must be an integer"; return 1 ;; esac
  if $WITH_PATCHES && [[ -z "$DEPLOYMENT" ]]; then
    fail "--with-patches requires --deployment or OPENCLAW_UPGRADE_DEPLOYMENT"
    return 1
  fi
}

resolve_platform() {
  if [[ -n "$PLATFORM_OVERRIDE" ]]; then
    PLATFORM="$PLATFORM_OVERRIDE"
    return 0
  fi
  case "$(uname -s)" in
    Darwin) PLATFORM="macos" ;;
    Linux) PLATFORM="linux" ;;
    *) fail "Unsupported platform: $(uname -s)"; return 1 ;;
  esac
}

ensure_runtime_dirs() {
  TIMESTAMP="$(date '+%Y%m%d-%H%M%S')"
  LOG_DIR="$OPENCLAW_HOME/logs"
  BACKUPS_DIR="$OPENCLAW_HOME/backups"
  LOCK_FILE="$OPENCLAW_HOME/.upgrade-lock"
  LOG_PATH="$LOG_DIR/upgrade-$TIMESTAMP.log"
  BACKUP_DIR="$BACKUPS_DIR/upgrade-$TIMESTAMP"
  mkdir -p "$OPENCLAW_HOME" "$LOG_DIR" "$BACKUPS_DIR"
}

setup_logging() {
  if [[ "$DRY_RUN" == true ]]; then
    LOG_PATH=""
    return 0
  fi

  if [[ "${OPENCLAW_UPGRADE_NO_TEE:-}" == "1" ]]; then
    exec >>"$LOG_PATH" 2>&1
    return 0
  fi

  exec > >(tee -a "$LOG_PATH") 2>&1
}

mode_label() {
  if [[ "$DRY_RUN" == true ]]; then
    printf 'dry-run\n'
  else
    printf '%s\n' "$MODE"
  fi
}

service_summary() {
  local loaded runtime
  loaded="$(json_get "$GATEWAY_STATUS_BEFORE_JSON" '.service.loaded')"
  runtime="$(json_get "$GATEWAY_STATUS_BEFORE_JSON" '.service.runtime.status')"

  if [[ -n "$runtime" ]]; then
    printf '%s (loaded=%s, runtime=%s)\n' "${SERVICE_LABEL:-unknown}" "${loaded:-unknown}" "$runtime"
  else
    printf '%s (loaded=%s)\n' "${SERVICE_LABEL:-unknown}" "${loaded:-unknown}"
  fi
}

describe_upgrade_path() {
  local preview_mode update_install_kind switch_to_git switch_to_package install_kind
  preview_mode="$(json_get "$UPDATE_PREVIEW_JSON" '.mode')"
  update_install_kind="$(json_get "$UPDATE_PREVIEW_JSON" '.updateInstallKind')"
  switch_to_git="$(json_get "$UPDATE_PREVIEW_JSON" '.switchToGit')"
  switch_to_package="$(json_get "$UPDATE_PREVIEW_JSON" '.switchToPackage')"
  install_kind="$(json_get "$UPDATE_PREVIEW_JSON" '.installKind')"

  if [[ "$switch_to_git" == "true" ]]; then
    printf 'package -> git checkout\n'
  elif [[ "$switch_to_package" == "true" ]]; then
    printf 'git checkout -> package install\n'
  elif [[ -n "$preview_mode" ]]; then
    printf '%s update via %s\n' "${update_install_kind:-${install_kind:-unknown}}" "$preview_mode"
  elif [[ -n "$install_kind" ]]; then
    printf '%s update\n' "$install_kind"
  elif [[ -n "$INSTALL_KIND" ]]; then
    printf '%s update\n' "$INSTALL_KIND"
  else
    printf 'unknown\n'
  fi
}

print_dry_run_summary() {
  local current_version target_version install_kind update_available requested_tag
  current_version="${PREVIOUS_VERSION:-$(json_get "$UPDATE_PREVIEW_JSON" '.currentVersion')}"
  target_version="$(json_get "$UPDATE_PREVIEW_JSON" '.targetVersion')"
  install_kind="$(json_get "$UPDATE_PREVIEW_JSON" '.installKind')"
  update_available="$(json_get "$UPDATE_STATUS_BEFORE_JSON" '.availability.available')"
  requested_tag="${TAG:-$(json_get "$UPDATE_PREVIEW_JSON" '.tag')}"

  log "Dry-run summary"
  log "  Platform: $PLATFORM"
  log "  Mode: $(mode_label)"
  log "  Service: $(service_summary)"
  log "  Install kind: ${install_kind:-${INSTALL_KIND:-unknown}}"
  if [[ -n "$UPDATE_ROOT" ]]; then
    log "  Install root: $UPDATE_ROOT"
  fi
  log "  Current version: ${current_version:-unknown}"
  log "  Available version: ${target_version:-unknown}"
  log "  Update available: ${update_available:-unknown}"
  log "  Upgrade path: $(describe_upgrade_path)"
  log "  Channel: $CHANNEL"
  if [[ -n "$requested_tag" ]]; then
    log "  Tag/spec: $requested_tag"
  fi

  if printf '%s' "$UPDATE_PREVIEW_JSON" | jq -e '.actions | type == "array" and length > 0' >/dev/null 2>&1; then
    log "  Planned actions:"
    while IFS= read -r action; do
      log "    - $action"
    done < <(printf '%s' "$UPDATE_PREVIEW_JSON" | jq -r '.actions[]')
  fi

  if printf '%s' "$UPDATE_PREVIEW_JSON" | jq -e '.notes | type == "array" and length > 0' >/dev/null 2>&1; then
    log "  Notes:"
    while IFS= read -r note; do
      log "    - $note"
    done < <(printf '%s' "$UPDATE_PREVIEW_JSON" | jq -r '.notes[]')
  fi
}

cleanup() {
  if $LOCK_ACQUIRED && [[ -f "$LOCK_FILE" ]]; then
    rm -f "$LOCK_FILE"
  fi
}

acquire_lock() {
  local payload existing_pid
  payload="$(jq -n --arg pid "$$" --arg started_at "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" --arg hostname "$(hostname)" '{pid: ($pid|tonumber), started_at: $started_at, hostname: $hostname}')"
  if ( set -o noclobber; printf '%s\n' "$payload" > "$LOCK_FILE" ) 2>/dev/null; then
    LOCK_ACQUIRED=true
    return 0
  fi
  existing_pid="$(jq -r '.pid // empty' "$LOCK_FILE" 2>/dev/null || true)"
  if [[ -n "$existing_pid" ]] && kill -0 "$existing_pid" 2>/dev/null; then
    fail "Upgrade lock already held by PID $existing_pid"
    return "$EXIT_LOCK"
  fi
  warn "Removing stale upgrade lock${existing_pid:+ for PID $existing_pid}"
  rm -f "$LOCK_FILE"
  if ( set -o noclobber; printf '%s\n' "$payload" > "$LOCK_FILE" ) 2>/dev/null; then
    LOCK_ACQUIRED=true
    return 0
  fi
  fail "Could not acquire upgrade lock"
  return "$EXIT_LOCK"
}

check_disk_space() {
  local available_kb required_kb
  available_kb="$(df -Pk "$OPENCLAW_HOME" | awk 'NR==2 { print $4 }')"
  required_kb=$((DISK_THRESHOLD_MB * 1024))
  if [[ -z "$available_kb" || "$available_kb" -lt "$required_kb" ]]; then
    fail "Insufficient free disk space: need ${DISK_THRESHOLD_MB}MB"
    return 1
  fi
}

warn_if_auto_update_enabled() {
  local value
  if value="$(run_capture_stdout openclaw config get update.auto.enabled --json 2>/dev/null)"; then
    if [[ "$value" == "true" ]]; then
      warn "update.auto.enabled=true may conflict with wrapper-based upgrades"
    fi
  fi
}

build_preview_args() {
  PREVIEW_ARGS=(openclaw update --json --no-restart --dry-run --timeout "$TIMEOUT" --channel "$CHANNEL")
  [[ -n "$TAG" ]] && PREVIEW_ARGS+=(--tag "$TAG")
}

build_apply_args() {
  APPLY_ARGS=(openclaw update --yes --json --no-restart --timeout "$TIMEOUT" --channel "$CHANNEL")
  [[ -n "$TAG" ]] && APPLY_ARGS+=(--tag "$TAG")
}

preflight() {
  need_cmd openclaw
  need_cmd jq
  need_cmd git
  need_cmd tar
  need_cmd date
  need_cmd df
  need_cmd hostname
  [[ -n "$WEBHOOK_URL" ]] && need_cmd curl
  if [[ "$PLATFORM" == "linux" && "$DRY_RUN" == false ]]; then need_cmd systemctl; fi
  if [[ "$PLATFORM" == "macos" && "$DRY_RUN" == false ]]; then need_cmd launchctl; fi

  check_disk_space

  GATEWAY_STATUS_BEFORE_JSON="$(run_capture_stdout openclaw gateway status --json)" || { fail "openclaw gateway status --json failed"; return 1; }
  printf '%s' "$GATEWAY_STATUS_BEFORE_JSON" | jq -e '.service.loaded == true' >/dev/null 2>&1 || { fail "Gateway service is not installed/loaded"; return 1; }
  SERVICE_LABEL="$(json_get "$GATEWAY_STATUS_BEFORE_JSON" '.service.label')"

  # Validate the reported label — openclaw gateway status --json can return
  # generic values like "LaunchAgent" or "systemd" instead of the real service
  # identifier. Fall back to well-known defaults when the label is missing or
  # doesn't look like a real service name (must contain a dot for launchd, or
  # end with .service for systemd).
  if [[ "$PLATFORM" == "linux" ]]; then
    if [[ -n "$SERVICE_LABEL" && "$SERVICE_LABEL" == *"."* ]]; then
      [[ "$SERVICE_LABEL" == *.service ]] && SERVICE_UNIT="$SERVICE_LABEL" || SERVICE_UNIT="$SERVICE_LABEL.service"
    else
      [[ -n "$SERVICE_LABEL" && "$SERVICE_LABEL" != "systemd" ]] && warn "Ignoring suspicious service label from gateway status: '$SERVICE_LABEL'"
      SERVICE_UNIT="openclaw-gateway.service"
      SERVICE_LABEL="openclaw-gateway"
    fi
  else
    if [[ -z "$SERVICE_LABEL" || "$SERVICE_LABEL" == "LaunchAgent" || ! "$SERVICE_LABEL" == *"."* ]]; then
      [[ -n "$SERVICE_LABEL" && "$SERVICE_LABEL" != "ai.openclaw.gateway" ]] && warn "Ignoring suspicious service label from gateway status: '$SERVICE_LABEL'"
      # Try to read the real label directly from the plist as ground truth
      local plist_path
      plist_path="$(json_get "$GATEWAY_STATUS_BEFORE_JSON" '.service.command.sourcePath')"
      plist_path="${plist_path:-$HOME/Library/LaunchAgents/ai.openclaw.gateway.plist}"
      if [[ -f "$plist_path" ]]; then
        SERVICE_LABEL="$(/usr/libexec/PlistBuddy -c "Print :Label" "$plist_path" 2>/dev/null || true)"
      fi
      SERVICE_LABEL="${SERVICE_LABEL:-ai.openclaw.gateway}"
    fi
  fi

  UPDATE_STATUS_BEFORE_JSON="$(run_capture_stdout openclaw update status --json)" || { fail "openclaw update status --json failed"; return 1; }
  build_preview_args
  UPDATE_PREVIEW_JSON="$(run_capture_stdout "${PREVIEW_ARGS[@]}")" || { fail "openclaw update --dry-run --json failed"; return 1; }

  INSTALL_KIND="$(json_get "$UPDATE_STATUS_BEFORE_JSON" '.update.installKind')"
  UPDATE_ROOT="$(json_get "$UPDATE_STATUS_BEFORE_JSON" '.update.root')"
  PREVIOUS_GIT_SHA="$(json_get "$UPDATE_STATUS_BEFORE_JSON" '.update.git.sha')"
  PREVIOUS_VERSION="$(json_get "$UPDATE_PREVIEW_JSON" '.currentVersion')"

  run_logged openclaw doctor --non-interactive --yes || { fail "Preflight doctor failed"; return 1; }

  if [[ "$MODE" == "apply" ]]; then
    CRON_BEFORE_JSON="$(run_capture_stdout openclaw cron list --json)" || { fail "openclaw cron list --json failed"; return 1; }
    CRON_STATUS_BEFORE_JSON="$(run_capture_stdout openclaw cron status --json)" || { fail "openclaw cron status --json failed"; return 1; }
    SKILLS_BEFORE_JSON="$(run_capture_stdout openclaw skills list --json)" || { fail "openclaw skills list --json failed"; return 1; }
  fi

  warn_if_auto_update_enabled

  # Validate the resolved service label is actually reachable before we
  # attempt any update. This catches bad labels during dry-run, not just prod.
  validate_service_reachable || return 1
}

copy_if_present() {
  local src="$1" dest="$2"
  [[ -f "$src" ]] && cp -f "$src" "$dest"
}

resolve_workspace_manifest_path() {
  local candidate
  for candidate in "$OPENCLAW_HOME/workspace/config/workspace-manifest.json" "$OPENCLAW_HOME/workspace/workspace-manifest.json"; do
    [[ -f "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }
  done
  return 1
}

write_metadata_file() {
  local workspace_manifest_path previous_channel
  workspace_manifest_path="$(resolve_workspace_manifest_path || true)"
  previous_channel="$(json_get "$UPDATE_STATUS_BEFORE_JSON" '.channel.value')"
  jq -n \
    --arg timestamp "$TIMESTAMP" \
    --arg hostname "$(hostname)" \
    --arg platform "$PLATFORM" \
    --arg channel "$CHANNEL" \
    --arg tag "$TAG" \
    --arg mode "$MODE" \
    --arg install_kind "$INSTALL_KIND" \
    --arg update_root "$UPDATE_ROOT" \
    --arg previous_version "$PREVIOUS_VERSION" \
    --arg previous_git_sha "$PREVIOUS_GIT_SHA" \
    --arg previous_channel "$previous_channel" \
    --arg service_label "$SERVICE_LABEL" \
    --arg log_path "$LOG_PATH" \
    --arg backup_path "$BACKUP_DIR" \
    --arg deployment "$DEPLOYMENT" \
    --arg workspace_manifest_path "$workspace_manifest_path" \
    '{
      timestamp: $timestamp,
      hostname: $hostname,
      platform: $platform,
      requested: { channel: $channel, tag: $tag, mode: $mode, deployment: $deployment },
      install: { kind: $install_kind, root: $update_root, previous_version: $previous_version, previous_git_sha: $previous_git_sha, previous_channel: $previous_channel },
      service: { label: $service_label },
      paths: { log: $log_path, backup: $backup_path, workspace_manifest: $workspace_manifest_path }
    }' > "$BACKUP_DIR/metadata.json"
}

create_backup() {
  if [[ "$DRY_RUN" == true || "$MODE" == "notify-only" ]]; then return 0; fi
  mkdir -p "$BACKUP_DIR"
  copy_if_present "$OPENCLAW_HOME/openclaw.json" "$BACKUP_DIR/openclaw.json"
  copy_if_present "$OPENCLAW_HOME/.env" "$BACKUP_DIR/.env"
  copy_if_present "$OPENCLAW_HOME/agents/main/agent/auth-profiles.json" "$BACKUP_DIR/auth-profiles.json"
  local workspace_manifest
  workspace_manifest="$(resolve_workspace_manifest_path || true)"
  [[ -n "$workspace_manifest" ]] && cp -f "$workspace_manifest" "$BACKUP_DIR/workspace-manifest.json"
  printf '%s\n' "$GATEWAY_STATUS_BEFORE_JSON" > "$BACKUP_DIR/gateway-status-before.json"
  printf '%s\n' "$UPDATE_STATUS_BEFORE_JSON" > "$BACKUP_DIR/update-status-before.json"
  printf '%s\n' "$CRON_BEFORE_JSON" > "$BACKUP_DIR/cron-before.json"
  printf '%s\n' "$CRON_STATUS_BEFORE_JSON" > "$BACKUP_DIR/cron-status-before.json"
  printf '%s\n' "$SKILLS_BEFORE_JSON" > "$BACKUP_DIR/skills-before.json"
  write_metadata_file

  # Native backup: compressed archive with manifest + integrity verification.
  # Non-fatal — flat-file backup above is the primary rollback source.
  # Uses --no-include-workspace (config + credentials + sessions, not workspace
  # files which are already backed up by Arq).
  if openclaw backup create --no-include-workspace --verify --json \
      --output "$BACKUP_DIR/native-backup.tar.gz" \
      > "$BACKUP_DIR/native-backup-result.json" 2>&1; then
    log "Native backup created and verified: $BACKUP_DIR/native-backup.tar.gz"
  else
    warn "Native backup failed (non-fatal, flat-file backup is primary)"
  fi
}

run_update() {
  if [[ "$DRY_RUN" == true || "$MODE" == "notify-only" ]]; then
    UPDATE_RESULT_JSON="$UPDATE_PREVIEW_JSON"
    return 0
  fi
  build_apply_args
  UPDATE_RESULT_JSON="$(run_capture_stdout "${APPLY_ARGS[@]}")" || return 1
  printf '%s' "$UPDATE_RESULT_JSON" | jq -e '.status == "ok"' >/dev/null 2>&1 || { fail "Update JSON did not report status=ok"; return 1; }
  FINAL_VERSION="$(json_get "$UPDATE_RESULT_JSON" '.after.version')"
  [[ -z "$PREVIOUS_VERSION" ]] && PREVIOUS_VERSION="$(json_get "$UPDATE_RESULT_JSON" '.before.version')"
  return 0
}

restore_file_from_backup() {
  local backup_name="$1" target_path="$2"
  if [[ -f "$BACKUP_DIR/$backup_name" ]]; then
    mkdir -p "$(dirname "$target_path")"
    cp -f "$BACKUP_DIR/$backup_name" "$target_path"
  fi
}

restore_snapshot_files() {
  if [[ ! -d "$BACKUP_DIR" ]]; then warn "No backup directory available for restore"; return 1; fi
  restore_file_from_backup "openclaw.json" "$OPENCLAW_HOME/openclaw.json"
  restore_file_from_backup ".env" "$OPENCLAW_HOME/.env"
  restore_file_from_backup "auth-profiles.json" "$OPENCLAW_HOME/agents/main/agent/auth-profiles.json"
  local workspace_manifest_target
  workspace_manifest_target="$OPENCLAW_HOME/workspace/config/workspace-manifest.json"
  if [[ -f "$BACKUP_DIR/metadata.json" ]]; then
    workspace_manifest_target="$(jq -r '.paths.workspace_manifest // empty' "$BACKUP_DIR/metadata.json" 2>/dev/null || true)"
    workspace_manifest_target="${workspace_manifest_target:-$OPENCLAW_HOME/workspace/config/workspace-manifest.json}"
  fi
  if [[ -f "$BACKUP_DIR/workspace-manifest.json" ]]; then
    mkdir -p "$(dirname "$workspace_manifest_target")"
    cp -f "$BACKUP_DIR/workspace-manifest.json" "$workspace_manifest_target"
  fi
}

detect_source_package_manager() {
  local root="$1"
  if [[ -f "$root/bun.lock" || -f "$root/bun.lockb" ]]; then printf 'bun\n'; return 0; fi
  if [[ -f "$root/pnpm-lock.yaml" ]]; then printf 'pnpm\n'; return 0; fi
  if [[ -f "$root/package-lock.json" ]]; then printf 'npm\n'; return 0; fi
  if [[ -f "$root/yarn.lock" ]]; then printf 'yarn\n'; return 0; fi
  return 1
}

run_source_refresh() {
  local root="$1" manager build_exists=false
  manager="$(detect_source_package_manager "$root" || true)"
  [[ -z "$manager" ]] && { warn "Could not detect package manager for source rollback refresh"; return 0; }
  case "$manager" in
    bun) (cd "$root" && run_logged bun install --frozen-lockfile) ;;
    pnpm) (cd "$root" && run_logged pnpm install --frozen-lockfile) ;;
    npm) (cd "$root" && run_logged npm install) ;;
    yarn) (cd "$root" && run_logged yarn install --frozen-lockfile) ;;
  esac
  if [[ -f "$root/package.json" ]] && jq -e '.scripts.build != null' "$root/package.json" >/dev/null 2>&1; then build_exists=true; fi
  if [[ "$build_exists" == true ]]; then
    case "$manager" in
      bun) (cd "$root" && run_logged bun run build) ;;
      pnpm) (cd "$root" && run_logged pnpm build) ;;
      npm) (cd "$root" && run_logged npm run build) ;;
      yarn) (cd "$root" && run_logged yarn build) ;;
    esac
  fi
  run_logged openclaw gateway install --force || warn "openclaw gateway install --force failed during source refresh"
}

perform_version_rollback() {
  if [[ "$INSTALL_KIND" == "package" && -n "$PREVIOUS_VERSION" ]]; then
    local rollback_output
    rollback_output="$(run_capture_stdout openclaw update --yes --json --no-restart --timeout "$TIMEOUT" --tag "$PREVIOUS_VERSION")" || return 1
    printf '%s\n' "$rollback_output" > "$BACKUP_DIR/rollback-update.json"
    return 0
  fi
  if [[ -n "$UPDATE_ROOT" && -n "$PREVIOUS_GIT_SHA" && -d "$UPDATE_ROOT/.git" ]]; then
    run_logged git -C "$UPDATE_ROOT" checkout "$PREVIOUS_GIT_SHA" || return 1
    run_source_refresh "$UPDATE_ROOT" || return 1
    return 0
  fi
  warn "Insufficient metadata to perform version rollback"
  return 1
}

validate_service_reachable() {
  # Verify the service we'd restart actually exists in the service manager.
  # Called during preflight so dry-run catches bad labels before apply would.
  if [[ "$PLATFORM" == "macos" ]]; then
    if ! launchctl print "gui/$(id -u)/$SERVICE_LABEL" >/dev/null 2>&1; then
      fail "Service 'gui/$(id -u)/$SERVICE_LABEL' not found in launchd. Restart would fail."
      return 1
    fi
    log "Service validated: gui/$(id -u)/$SERVICE_LABEL (launchd)"
  else
    if ! systemctl --user cat "$SERVICE_UNIT" >/dev/null 2>&1; then
      fail "Service '$SERVICE_UNIT' not found in systemd. Restart would fail."
      return 1
    fi
    log "Service validated: $SERVICE_UNIT (systemd)"
  fi
}

restart_gateway() {
  if [[ "$DRY_RUN" == true || "$MODE" == "notify-only" ]]; then
    log "Dry run / notify-only: skipping service restart"
    return 0
  fi
  if [[ "$PLATFORM" == "macos" ]]; then
    # On macOS, we run inside the gateway process. Using kickstart -k kills us
    # mid-script (SIGPIPE). Instead: spawn a detached health checker, then send
    # SIGTERM to the gateway. launchd KeepAlive=true respawns it automatically.
    # The detached checker writes results to $BACKUP_DIR/health-check.json.
    spawn_detached_health_check
    local gw_pid
    gw_pid="$(launchctl print "gui/$(id -u)/$SERVICE_LABEL" 2>/dev/null | awk '/^\tpid =/{print $3}')"
    if [[ -n "$gw_pid" && "$gw_pid" -gt 0 ]]; then
      log "Sending SIGTERM to gateway (pid $gw_pid); launchd will respawn"
      kill -TERM "$gw_pid" 2>/dev/null || true
    else
      # Fallback: kickstart -k (old behavior) — may SIGPIPE us but at least restarts
      warn "Could not find gateway PID; falling back to kickstart -k"
      run_logged launchctl kickstart -k "gui/$(id -u)/$SERVICE_LABEL"
    fi
    # Script dies here when the gateway process exits — that's expected.
    # The detached health checker handles post-restart verification.
    return 0
  else
    run_logged systemctl --user restart "$SERVICE_UNIT"
  fi
}

spawn_detached_health_check() {
  # Launch a fully detached process that waits for the new gateway to become
  # healthy, captures post-upgrade state, verifies integrity, and writes a
  # result JSON. This process survives the gateway kill because it's detached
  # from the gateway's process group.
  local hc_script hc_log
  hc_log="${BACKUP_DIR}/health-check.log"

  hc_script="$(cat <<HEALTH_SCRIPT
#!/usr/bin/env bash
set -uo pipefail

# Wait for old gateway to die
sleep 5

HEALTH_TIMEOUT="${HEALTH_TIMEOUT}"
HEALTH_INTERVAL="${HEALTH_INTERVAL}"
BACKUP_DIR="${BACKUP_DIR}"
PREVIOUS_VERSION="${PREVIOUS_VERSION}"
FINAL_VERSION=""

log() { printf '[health-check] %s\n' "\$*"; }
fail() { printf '[health-check] ERROR: %s\n' "\$*" >&2; }

write_result() {
  local status="\$1" reason="\${2:-}" version="\${3:-}"
  jq -n \\
    --arg status "\$status" \\
    --arg reason "\$reason" \\
    --arg previous_version "$PREVIOUS_VERSION" \\
    --arg final_version "\$version" \\
    --arg checked_at "\$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \\
    '{status: \$status, reason: (if (\$reason | length) > 0 then \$reason else null end), previous_version: \$previous_version, final_version: \$final_version, checked_at: \$checked_at}' \\
    > "\$BACKUP_DIR/health-check.json"
}

# Wait for gateway to come up
deadline=\$(( \$(date +%s) + HEALTH_TIMEOUT ))
health_json=""
while true; do
  if health_json="\$(openclaw health --json --timeout 10000 2>/dev/null)"; then
    FINAL_VERSION="\$(printf '%s' "\$health_json" | jq -r '.version // empty' 2>/dev/null || true)"
    log "Gateway healthy (version: \${FINAL_VERSION:-unknown})"
    break
  fi
  now="\$(date +%s)"
  if [[ "\$now" -ge "\$deadline" ]]; then
    fail "Gateway health check timed out after \${HEALTH_TIMEOUT}s"
    write_result "failed" "health check timed out" ""
    exit 1
  fi
  sleep "\$HEALTH_INTERVAL"
done

# Capture post-update state
cron_after="\$(openclaw cron list --json 2>/dev/null || true)"
cron_status_after="\$(openclaw cron status --json 2>/dev/null || true)"
skills_after="\$(openclaw skills list --json 2>/dev/null || true)"

printf '%s\n' "\$cron_after" > "\$BACKUP_DIR/cron-after.json" 2>/dev/null || true
printf '%s\n' "\$cron_status_after" > "\$BACKUP_DIR/cron-status-after.json" 2>/dev/null || true
printf '%s\n' "\$skills_after" > "\$BACKUP_DIR/skills-after.json" 2>/dev/null || true

# Run doctor
if ! openclaw doctor --non-interactive --yes >"\$BACKUP_DIR/doctor-post.log" 2>&1; then
  log "Post-restart doctor had warnings (see doctor-post.log)"
fi

write_result "success" "" "\$FINAL_VERSION"
log "Health check complete: success (version: \${FINAL_VERSION:-unknown})"
HEALTH_SCRIPT
)"

  # Write and execute as detached process
  local hc_path="${BACKUP_DIR}/health-check.sh"
  printf '%s\n' "$hc_script" > "$hc_path"
  chmod +x "$hc_path"
  log "Spawning detached health checker: $hc_path (log: $hc_log)"
  nohup "$hc_path" > "$hc_log" 2>&1 < /dev/null &
  disown
}

wait_for_health() {
  if [[ "$PLATFORM" == "macos" && "$DRY_RUN" != true && "$MODE" != "notify-only" ]]; then
    # On macOS, the detached health checker handles this. We'll be dead by the
    # time launchd respawns the gateway, so this is a no-op. The script will
    # exit (SIGTERM/SIGPIPE) before reaching post-restart steps — that's fine.
    log "Health check delegated to detached process"
    return 0
  fi
  local deadline now
  deadline=$(( $(date +%s) + HEALTH_TIMEOUT ))
  while true; do
    if HEALTH_JSON="$(run_capture_stdout openclaw health --json --timeout 10000)"; then
      FINAL_VERSION="${FINAL_VERSION:-$(json_get "$HEALTH_JSON" '.version')}"
      return 0
    fi
    now="$(date +%s)"
    if [[ "$now" -ge "$deadline" ]]; then
      fail "Gateway health check timed out after ${HEALTH_TIMEOUT}s"
      return 1
    fi
    sleep "$HEALTH_INTERVAL"
  done
}

capture_post_update_state() {
  CRON_AFTER_JSON="$(run_capture_stdout openclaw cron list --json)" || return 1
  CRON_STATUS_AFTER_JSON="$(run_capture_stdout openclaw cron status --json)" || return 1
  SKILLS_AFTER_JSON="$(run_capture_stdout openclaw skills list --json)" || return 1
}

extract_cron_keys() {
  local json_input="$1"
  printf '%s' "$json_input" | jq -r '
    def items:
      if type == "array" then .[]
      elif type == "object" then (.jobs // .items // .entries // .cron // .data // [])[]?
      else empty end;
    items | [(.id // ""), (.name // "")] | @tsv
  ' 2>/dev/null | sed '/^\t$/d' | LC_ALL=C sort -u
}

extract_skill_keys() {
  local json_input="$1"
  printf '%s' "$json_input" | jq -r '
    def items:
      if type == "array" then .[]
      elif type == "object" then (.skills // .items // .entries // .available // .data // [])[]?
      else empty end;
    items | (.name // .id // .slug // empty)
  ' 2>/dev/null | sed '/^$/d' | LC_ALL=C sort -u
}

compare_sets() {
  local before="$1" after="$2" before_file after_file missing_file
  before_file="$(mktemp "${TMPDIR:-/tmp}/openclaw-upgrade.before.XXXXXX")"
  after_file="$(mktemp "${TMPDIR:-/tmp}/openclaw-upgrade.after.XXXXXX")"
  missing_file="$(mktemp "${TMPDIR:-/tmp}/openclaw-upgrade.missing.XXXXXX")"
  printf '%s\n' "$before" > "$before_file"
  printf '%s\n' "$after" > "$after_file"
  comm -23 "$before_file" "$after_file" > "$missing_file" || true
  cat "$missing_file"
  rm -f "$before_file" "$after_file" "$missing_file"
}

verify_integrity() {
  local before_cron after_cron before_skills after_skills missing
  before_cron="$(extract_cron_keys "$CRON_BEFORE_JSON")"
  after_cron="$(extract_cron_keys "$CRON_AFTER_JSON")"
  missing="$(compare_sets "$before_cron" "$after_cron")"
  if [[ -n "$missing" ]]; then
    fail "Cron integrity check failed; missing entries: $(echo "$missing" | tr '\n' ' ' | sed 's/[[:space:]]\+$//')"
    return 1
  fi
  before_skills="$(extract_skill_keys "$SKILLS_BEFORE_JSON")"
  after_skills="$(extract_skill_keys "$SKILLS_AFTER_JSON")"
  missing="$(compare_sets "$before_skills" "$after_skills")"
  if [[ -n "$missing" ]]; then
    fail "Skills integrity check failed; missing entries: $(echo "$missing" | tr '\n' ' ' | sed 's/[[:space:]]\+$//')"
    return 1
  fi
}

resolve_patch_command() {
  if [[ -x "$PATCH_SCRIPT_DEFAULT" ]]; then printf '%s\n' "$PATCH_SCRIPT_DEFAULT"; return 0; fi
  if command -v openclaw-patch >/dev/null 2>&1; then command -v openclaw-patch; return 0; fi
  return 1
}

run_patch_sync() {
  local patch_cmd
  patch_cmd="$(resolve_patch_command || true)"
  if [[ -z "$patch_cmd" ]]; then PATCH_STATUS="missing"; warn "Patch sync requested but openclaw-patch is unavailable"; return 1; fi
  if [[ -z "$DEPLOYMENT" ]]; then PATCH_STATUS="missing-deployment"; warn "Patch sync requested but no deployment name is configured"; return 1; fi
  if run_logged "$patch_cmd" sync --deployment "$DEPLOYMENT"; then PATCH_STATUS="success"; return 0; fi
  PATCH_STATUS="failed"
  return 1
}

prune_backups() {
  local backups=() index
  if [[ "$DRY_RUN" == true || "$MODE" == "notify-only" ]]; then return 0; fi
  if [[ -d "$BACKUPS_DIR" ]]; then
    while IFS= read -r line; do backups+=("$line"); done < <(ls -1dt "$BACKUPS_DIR"/upgrade-* 2>/dev/null || true)
    for (( index=RETAIN_COUNT; index<${#backups[@]}; index+=1 )); do rm -rf "${backups[$index]}"; done
    find "$BACKUPS_DIR" -mindepth 1 -maxdepth 1 -type d -name 'upgrade-*' -mtime "+$RETAIN_DAYS" -exec rm -rf {} + 2>/dev/null || true
  fi
}

build_result_json() {
  local duration_seconds
  duration_seconds=$(( $(date +%s) - START_EPOCH ))
  jq -n \
    --arg status "$FINAL_STATUS" \
    --arg reason "$FAILURE_REASON" \
    --arg host "$(hostname)" \
    --arg platform "$PLATFORM" \
    --arg channel "$CHANNEL" \
    --arg tag "$TAG" \
    --arg deployment "$DEPLOYMENT" \
    --arg previous_version "$PREVIOUS_VERSION" \
    --arg final_version "$FINAL_VERSION" \
    --arg log_path "$LOG_PATH" \
    --arg backup_path "$BACKUP_DIR" \
    --arg patch_status "$PATCH_STATUS" \
    --argjson exit_code "$FINAL_EXIT_CODE" \
    --argjson duration_seconds "$duration_seconds" \
    '{
      status: $status,
      reason: (if ($reason | length) > 0 then $reason else null end),
      host: $host,
      platform: $platform,
      channel: $channel,
      tag: (if ($tag | length) > 0 then $tag else null end),
      deployment: (if ($deployment | length) > 0 then $deployment else null end),
      previous_version: (if ($previous_version | length) > 0 then $previous_version else null end),
      final_version: (if ($final_version | length) > 0 then $final_version else null end),
      duration_seconds: $duration_seconds,
      exit_code: $exit_code,
      log_path: (if ($log_path | length) > 0 then $log_path else null end),
      backup_path: (if ($backup_path | length) > 0 then $backup_path else null end),
      patch_status: $patch_status
    }'
}

send_webhook() {
  local payload="$1"
  [[ -z "$WEBHOOK_URL" ]] && return 0
  curl -fsS -X POST -H 'Content-Type: application/json' -d "$payload" "$WEBHOOK_URL" >/dev/null || { warn "Webhook notification failed"; return 1; }
}

send_notify_message() {
  local payload="$1" status_text message
  [[ "$NOTIFY" != true ]] && return 0
  if [[ -z "$NOTIFY_CHANNEL" || -z "$NOTIFY_TARGET" ]]; then warn "--notify was set but notify channel/target is missing"; return 1; fi
  status_text="$(printf '%s' "$payload" | jq -r '.status')"
  message="OpenClaw upgrade ${status_text} on $(hostname)"
  if [[ -n "$PREVIOUS_VERSION" || -n "$FINAL_VERSION" ]]; then message+=" (${PREVIOUS_VERSION:-unknown} -> ${FINAL_VERSION:-unknown})"; fi
  [[ -n "$DEPLOYMENT" ]] && message+=" [${DEPLOYMENT}]"
  run_logged openclaw message send --channel "$NOTIFY_CHANNEL" --target "$NOTIFY_TARGET" --message "$message" >/dev/null || { warn "openclaw message send notification failed"; return 1; }
}

finalize_result() {
  local result_json
  result_json="$(build_result_json)"
  if [[ -n "$BACKUP_DIR" && -d "$BACKUP_DIR" ]]; then
    printf '%s\n' "$result_json" > "$BACKUP_DIR/result.json"
  fi
  send_webhook "$result_json" || true
  send_notify_message "$result_json" || true
  log "Final status: $FINAL_STATUS (exit $FINAL_EXIT_CODE)"
}

attempt_rollback() {
  log "Starting rollback flow"
  restore_snapshot_files || true
  perform_version_rollback || { FINAL_STATUS="rollback_failure"; return 1; }
  # On macOS, restart_gateway kills us — launchd respawns with rolled-back version.
  # That's the desired outcome. We won't reach wait_for_health or doctor.
  restart_gateway || { FINAL_STATUS="rollback_failure"; return 1; }
  wait_for_health || { FINAL_STATUS="rollback_failure"; return 1; }
  run_logged openclaw doctor --non-interactive --yes || { FINAL_STATUS="rollback_failure"; return 1; }
  FINAL_STATUS="rollback_success"
}

fail_and_exit() {
  local reason="$1" exit_code="$2"
  FAILURE_REASON="$reason"
  FINAL_EXIT_CODE="$exit_code"
  FINAL_STATUS="failure"
  fail "$reason"
  if [[ "$DRY_RUN" == false && "$MODE" == "apply" && -d "$BACKUP_DIR" ]]; then
    if attempt_rollback; then
      FINAL_EXIT_CODE="$EXIT_ROLLBACK"
    fi
  fi
  finalize_result
  return "$FINAL_EXIT_CODE"
}

main() {
  local parse_rc=0
  START_EPOCH="$(date +%s)"
  load_config_file
  parse_args "$@" || parse_rc=$?
  if [[ "$parse_rc" -ne 0 ]]; then
    [[ "$parse_rc" -eq 1 ]] && return 0
    return "$EXIT_FAILURE"
  fi
  validate_args || return "$EXIT_FAILURE"
  resolve_platform || return "$EXIT_FAILURE"
  ensure_runtime_dirs
  setup_logging
  trap cleanup EXIT INT TERM

  log "Starting OpenClaw upgrade"
  log "Mode=$(mode_label) Channel=$CHANNEL Tag=${TAG:-<none>} Platform=$PLATFORM Deployment=${DEPLOYMENT:-<none>}"

  acquire_lock || return $?
  preflight || return "$EXIT_FAILURE"

  if [[ "$MODE" == "notify-only" || "$DRY_RUN" == true ]]; then
    if [[ "$DRY_RUN" == true ]]; then
      print_dry_run_summary
    fi
    FINAL_STATUS="success"
    FINAL_EXIT_CODE="$EXIT_SUCCESS"
    FINAL_VERSION="$(json_get "$UPDATE_PREVIEW_JSON" '.targetVersion')"
    finalize_result
    return "$FINAL_EXIT_CODE"
  fi

  create_backup || return "$EXIT_FAILURE"
  if ! run_update; then fail_and_exit "openclaw update failed" "$EXIT_FAILURE"; return "$FINAL_EXIT_CODE"; fi
  if ! run_logged openclaw doctor --non-interactive --yes; then fail_and_exit "Post-update doctor failed" "$EXIT_FAILURE"; return "$FINAL_EXIT_CODE"; fi

  # On macOS, restart_gateway sends SIGTERM and we die with the process.
  # The detached health checker (spawned inside restart_gateway) handles
  # post-restart verification. Everything after this point is best-effort.
  if ! restart_gateway; then fail_and_exit "Gateway restart failed" "$EXIT_FAILURE"; return "$FINAL_EXIT_CODE"; fi

  # --- Below here may never execute on macOS (we're dying with the gateway) ---

  if ! wait_for_health; then fail_and_exit "Gateway health check failed" "$EXIT_HEALTH"; return "$FINAL_EXIT_CODE"; fi
  if ! capture_post_update_state; then fail_and_exit "Post-upgrade cron/skills snapshot failed" "$EXIT_FAILURE"; return "$FINAL_EXIT_CODE"; fi
  if ! verify_integrity; then fail_and_exit "Cron/skills integrity verification failed" "$EXIT_FAILURE"; return "$FINAL_EXIT_CODE"; fi

  FINAL_STATUS="success"
  FINAL_EXIT_CODE="$EXIT_SUCCESS"
  if $WITH_PATCHES; then
    if ! run_patch_sync; then
      FINAL_STATUS="degraded"
      FINAL_EXIT_CODE="$EXIT_FAILURE"
      FAILURE_REASON="openclaw-patch sync failed"
    fi
  else
    PATCH_STATUS="not-requested"
  fi
  prune_backups || true
  finalize_result
  return "$FINAL_EXIT_CODE"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
  exit $?
fi
