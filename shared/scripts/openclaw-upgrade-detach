#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UPGRADE_SCRIPT="$SCRIPT_DIR/openclaw-upgrade"

if [[ ! -x "$UPGRADE_SCRIPT" ]]; then
  echo "openclaw-upgrade not found or not executable: $UPGRADE_SCRIPT" >&2
  exit 1
fi

if command -v setsid >/dev/null 2>&1; then
  setsid "$UPGRADE_SCRIPT" "$@" >/dev/null 2>&1 < /dev/null &
else
  nohup "$UPGRADE_SCRIPT" "$@" >/dev/null 2>&1 < /dev/null &
fi

echo "$!"
