{
  "tools": {
    "web": {
      "search": {
        "provider": "perplexity"
      }
    },
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    },
    "exec": {
      "security": "full",
      "ask": "off"
    },
    "fs": {
      "workspaceOnly": false
    },
    "elevated": {
      "enabled": true
    },
    "media": {
      "audio": {
        "enabled": true
      }
    }
  }
}
