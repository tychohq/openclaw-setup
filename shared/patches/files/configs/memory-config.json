{
  "agents": {
    "defaults": {
      "memorySearch": {
        "sources": ["memory", "sessions"],
        "extraPaths": ["."],
        "experimental": {
          "sessionMemory": true
        },
        "provider": "openai",
        "remote": {
          "batch": {
            "enabled": false
          }
        },
        "fallback": "none",
        "sync": {
          "sessions": {
            "deltaBytes": 1,
            "deltaMessages": 1
          }
        }
      }
    }
  },
  "memory": {
    "backend": "builtin"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        }
      }
    }
  }
}
