{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": [
          "openai-codex/gpt-5.3-codex"
        ]
      },
      "compaction": {
        "reserveTokensFloor": 80000
      },
      "heartbeat": {
        "every": "1h"
      },
      "maxConcurrent": 6,
      "verboseDefault": "off",
      "blockStreamingDefault": "on",
      "contextPruning": {
        "mode": "off",
        "ttl": "1h"
      }
    }
  }
}
