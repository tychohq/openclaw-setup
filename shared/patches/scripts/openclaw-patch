#!/usr/bin/env bash
set -euo pipefail

# ── openclaw-patch — Declarative patch system for OpenClaw deployments ────────
#
# Usage:
#   openclaw-patch new <name>                     Create a new patch scaffold
#   openclaw-patch list                           List all patches
#   openclaw-patch validate [patch]               Validate patch manifests
#   openclaw-patch publish                        Validate, commit, and push
#   openclaw-patch pull                           Git pull latest patches
#   openclaw-patch apply --deployment <name>      Apply pending patches
#   openclaw-patch status --deployment <name>     Show applied/pending patches
#   openclaw-patch sync --deployment <name>       Pull + apply in one shot
#   openclaw-patch diff --deployment <name>       Show what would change
#
# Environment:
#   OPENCLAW_PATCHES_DIR   Override the repo root (default: auto-detect)
#   OPENCLAW_HOME          Override OpenClaw home (default: ~/.openclaw)

VERSION="0.1.0"

# ── Resolve Paths ─────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -n "${OPENCLAW_PATCHES_DIR:-}" ]]; then
  REPO_ROOT="$OPENCLAW_PATCHES_DIR"
else
  REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

PATCHES_DIR="$REPO_ROOT/patches"
FILES_DIR="$REPO_ROOT/files"
SKILLS_DIR="$REPO_ROOT/skills"

OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
STATE_DIR="$OPENCLAW_HOME/patches"
APPLIED_FILE="$STATE_DIR/applied.json"

# ── Helpers ───────────────────────────────────────────────────────────────────

die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "→ $*"; }
warn() { echo "⚠ $*" >&2; }
ok()   { echo "✓ $*"; }

need_cmd() {
  command -v "$1" &>/dev/null || die "Required command not found: $1"
}

# Minimal YAML parser — extracts top-level scalar fields from a patch manifest.
# Handles: `key: value`, `key: "value"`, `key: 'value'`
# For complex fields (steps, merge blocks), we use the section extractors below.
yaml_get() {
  local file="$1" key="$2"
  grep -E "^${key}:" "$file" 2>/dev/null | head -1 | sed -E "s/^${key}:[[:space:]]*//" | sed -E 's/^["'"'"']|["'"'"']$//g'
}

# Extract the targets array as space-separated values
yaml_get_targets() {
  local file="$1"
  grep -E "^targets:" "$file" 2>/dev/null | head -1 | sed -E 's/^targets:[[:space:]]*\[//;s/\][[:space:]]*$//' | tr ',' '\n' | sed -E 's/^[[:space:]]*["'"'"']?//;s/["'"'"']?[[:space:]]*$//' | tr '\n' ' '
}

# Check if a deployment matches the targets list
matches_target() {
  local deployment="$1"
  shift
  local targets=("$@")
  
  [[ ${#targets[@]} -eq 0 ]] && return 0  # no targets = matches all
  
  for t in "${targets[@]}"; do
    [[ "$t" == "*" || "$t" == "$deployment" ]] && return 0
  done
  return 1
}

# Initialize state directory
init_state() {
  mkdir -p "$STATE_DIR"
  if [[ ! -f "$APPLIED_FILE" ]]; then
    echo '{}' > "$APPLIED_FILE"
  fi
}

# Check if a patch has been applied
is_applied() {
  local patch_id="$1"
  if command -v jq &>/dev/null; then
    jq -e --arg id "$patch_id" '.[$id] != null' "$APPLIED_FILE" &>/dev/null
  else
    grep -q "\"$patch_id\"" "$APPLIED_FILE" 2>/dev/null
  fi
}

# Mark a patch as applied
mark_applied() {
  local patch_id="$1"
  local timestamp
  timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  
  if command -v jq &>/dev/null; then
    local tmp
    tmp=$(mktemp)
    jq --arg id "$patch_id" --arg ts "$timestamp" '.[$id] = {"applied_at": $ts}' "$APPLIED_FILE" > "$tmp"
    mv "$tmp" "$APPLIED_FILE"
  else
    # Fallback: simple append (not proper JSON merge, but works for checking)
    sed -i.bak "s/}$/,\"$patch_id\":{\"applied_at\":\"$timestamp\"}}/" "$APPLIED_FILE"
    rm -f "${APPLIED_FILE}.bak"
  fi
}

# Get sorted list of patch files (by created timestamp)
get_sorted_patches() {
  local patches=()
  for f in "$PATCHES_DIR"/*.yaml "$PATCHES_DIR"/*.yml; do
    [[ -f "$f" ]] || continue
    local created
    created="$(yaml_get "$f" "created")"
    [[ -z "$created" ]] && created="9999-99-99"
    patches+=("$created|$f")
  done
  
  printf '%s\n' "${patches[@]}" | sort | cut -d'|' -f2
}

# ── Step Executors ────────────────────────────────────────────────────────────

# Execute a single step from a patch.
# Steps are passed as a temp file containing the YAML block for that step.
exec_step() {
  local step_file="$1"
  local step_type
  step_type="$(yaml_get "$step_file" "type")"
  
  case "$step_type" in
    file)           exec_step_file "$step_file" ;;
    config_patch)   exec_step_config_patch "$step_file" ;;
    skill)          exec_step_skill "$step_file" ;;
    clawhub)        exec_step_clawhub "$step_file" ;;
    cron)           exec_step_cron "$step_file" ;;
    exec)           exec_step_exec "$step_file" ;;
    openclaw_update) exec_step_openclaw_update "$step_file" ;;
    restart)        exec_step_restart ;;
    *)              warn "Unknown step type: $step_type (skipping)" ;;
  esac
}

exec_step_file() {
  local step_file="$1"
  local target_path content_file content_inline
  
  target_path="$(yaml_get "$step_file" "path")"
  content_file="$(yaml_get "$step_file" "content_file")"
  content_inline="$(yaml_get "$step_file" "content")"
  
  # Expand ~ to $HOME
  target_path="${target_path/#\~/$HOME}"
  
  [[ -z "$target_path" ]] && die "file step missing 'path'"
  
  mkdir -p "$(dirname "$target_path")"
  
  if [[ -n "$content_file" ]]; then
    local source_path="$FILES_DIR/$content_file"
    [[ -f "$source_path" ]] || die "content_file not found: $source_path"
    cp "$source_path" "$target_path"
    info "Wrote $target_path (from $content_file)"
  elif [[ -n "$content_inline" ]]; then
    echo "$content_inline" > "$target_path"
    info "Wrote $target_path (inline)"
  else
    # Check for multi-line content block
    die "file step needs 'content_file' or 'content'"
  fi
}

exec_step_config_patch() {
  local step_file="$1"
  need_cmd jq
  
  local config_file="$OPENCLAW_HOME/openclaw.json"
  [[ -f "$config_file" ]] || die "openclaw.json not found at $config_file"
  
  # Extract the merge block — everything indented under "merge:" until next top-level key
  local merge_json_file
  merge_json_file="$(yaml_get "$step_file" "merge_file")"
  
  if [[ -n "$merge_json_file" ]]; then
    local source="$FILES_DIR/$merge_json_file"
    [[ -f "$source" ]] || die "merge_file not found: $source"
    
    local tmp
    tmp=$(mktemp)
    jq -s '.[0] * .[1]' "$config_file" "$source" > "$tmp"
    mv "$tmp" "$config_file"
    info "Config patched from $merge_json_file"
  else
    warn "config_patch step without merge_file — use a JSON file in files/"
  fi
}

exec_step_skill() {
  local step_file="$1"
  local skill_name source_dir
  
  skill_name="$(yaml_get "$step_file" "name")"
  source_dir="$(yaml_get "$step_file" "source_dir")"
  
  [[ -z "$skill_name" ]] && die "skill step missing 'name'"
  
  local source_path
  if [[ -n "$source_dir" ]]; then
    source_path="$SKILLS_DIR/$source_dir"
  else
    source_path="$SKILLS_DIR/$skill_name"
  fi
  
  [[ -d "$source_path" ]] || die "Skill directory not found: $source_path"
  
  local dest="$OPENCLAW_HOME/skills/$skill_name"
  mkdir -p "$dest"
  cp -r "$source_path"/* "$dest/"
  info "Skill installed: $skill_name → $dest"
}

exec_step_clawhub() {
  local step_file="$1"
  need_cmd clawhub
  
  # Read skills list from the step file
  local line
  local in_skills=false
  while IFS= read -r line; do
    if [[ "$line" =~ ^skills: ]]; then
      in_skills=true
      continue
    fi
    if $in_skills; then
      if [[ "$line" =~ ^[[:space:]]*-[[:space:]]+(.*) ]]; then
        local skill="${BASH_REMATCH[1]}"
        skill="$(echo "$skill" | sed -E 's/^["'"'"']|["'"'"']$//g')"
        info "Installing ClawHub skill: $skill"
        clawhub install "$skill" || warn "Failed to install: $skill"
      else
        break
      fi
    fi
  done < "$step_file"
}

exec_step_cron() {
  local step_file="$1"
  local cron_name job_file
  
  cron_name="$(yaml_get "$step_file" "name")"
  job_file="$(yaml_get "$step_file" "job_file")"
  
  [[ -z "$cron_name" ]] && die "cron step missing 'name'"
  
  if [[ -n "$job_file" ]]; then
    local source="$FILES_DIR/$job_file"
    [[ -f "$source" ]] || die "job_file not found: $source"
    
    local dest_dir="$OPENCLAW_HOME/workspace/cron-jobs"
    mkdir -p "$dest_dir"
    cp "$source" "$dest_dir/${cron_name}.json"
    info "Cron job written: $cron_name → $dest_dir/${cron_name}.json"
    info "Note: Job needs to be registered via 'openclaw cron add' or the gateway API"
  else
    warn "cron step without job_file — use a JSON file in files/"
  fi
}

exec_step_exec() {
  local step_file="$1"
  local cmd
  cmd="$(yaml_get "$step_file" "command")"
  
  [[ -z "$cmd" ]] && die "exec step missing 'command'"
  
  info "Running: $cmd"
  eval "$cmd"
}

exec_step_openclaw_update() {
  local step_file="$1"
  local target_version
  target_version="$(yaml_get "$step_file" "version")"
  
  if [[ "$target_version" == "latest" || -z "$target_version" ]]; then
    info "Updating OpenClaw to latest..."
    npm install -g openclaw
  else
    info "Updating OpenClaw to $target_version..."
    npm install -g "openclaw@$target_version"
  fi
}

exec_step_restart() {
  info "Restarting OpenClaw gateway..."
  if command -v systemctl &>/dev/null && systemctl --user is-active openclaw-gateway &>/dev/null; then
    systemctl --user restart openclaw-gateway
  elif command -v openclaw &>/dev/null; then
    openclaw gateway restart || true
  else
    warn "Could not restart gateway — no systemctl or openclaw CLI found"
  fi
}

# ── Parse Steps from YAML ─────────────────────────────────────────────────────
# Splits a patch YAML into individual step temp files.
# Each step block starts with "  - type:" and continues until the next "  - type:" or EOF.

parse_steps() {
  local patch_file="$1"
  local output_dir="$2"
  
  local in_steps=false
  local step_num=0
  local current_file=""
  
  while IFS= read -r line; do
    # Detect start of steps section
    if [[ "$line" =~ ^steps: ]]; then
      in_steps=true
      continue
    fi
    
    # Before steps section, skip
    $in_steps || continue
    
    # New top-level key after steps — we're done
    if [[ "$line" =~ ^[a-z] ]]; then
      break
    fi
    
    # New step item
    if [[ "$line" =~ ^[[:space:]]*-[[:space:]]+type:[[:space:]]+(.*) ]]; then
      step_num=$((step_num + 1))
      current_file="$output_dir/step-$(printf '%03d' $step_num).yaml"
      echo "type: ${BASH_REMATCH[1]}" > "$current_file"
      continue
    fi
    
    # Continuation of current step (strip leading whitespace for our mini-parser)
    if [[ -n "$current_file" && "$line" =~ ^[[:space:]]{4,}(.*) ]]; then
      local content="${BASH_REMATCH[1]}"
      echo "$content" >> "$current_file"
    fi
  done < "$patch_file"
  
  echo "$step_num"
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_new() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: openclaw-patch new <name>"
  
  local patch_file="$PATCHES_DIR/${name}.yaml"
  [[ -f "$patch_file" ]] && die "Patch already exists: $patch_file"
  
  local now
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  
  cat > "$patch_file" << EOF
id: $name
description: ""
targets: ["*"]
created: $now

steps:
  # - type: file
  #   path: ~/.openclaw/workspace/EXAMPLE.md
  #   content_file: example.md

  # - type: config_patch
  #   merge_file: example-config.json

  # - type: skill
  #   name: my-skill

  # - type: clawhub
  #   skills:
  #     - "weather@latest"

  # - type: cron
  #   name: my-cron-job
  #   job_file: my-cron-job.json

  # - type: exec
  #   command: "echo hello"

  # - type: openclaw_update
  #   version: latest

  # - type: restart
EOF

  ok "Created patch: $patch_file"
  echo "  Edit the manifest, add referenced files to files/ or skills/"
}

cmd_list() {
  echo "Patches in $PATCHES_DIR:"
  echo ""
  
  local count=0
  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    local id desc created targets_str
    id="$(yaml_get "$f" "id")"
    desc="$(yaml_get "$f" "description")"
    created="$(yaml_get "$f" "created")"
    targets_str="$(yaml_get_targets "$f")"
    
    local applied_marker=""
    if [[ -f "$APPLIED_FILE" ]] && is_applied "$id" 2>/dev/null; then
      applied_marker=" ✓"
    fi
    
    printf "  %-30s %s%s\n" "$id" "$desc" "$applied_marker"
    printf "    created: %s  targets: [%s]\n" "$created" "$targets_str"
    echo ""
    count=$((count + 1))
  done < <(get_sorted_patches)
  
  [[ $count -eq 0 ]] && echo "  (no patches yet)"
}

cmd_validate() {
  local target="${1:-}"
  local files=()
  
  if [[ -n "$target" ]]; then
    files=("$PATCHES_DIR/$target.yaml" "$PATCHES_DIR/$target.yml")
  else
    for f in "$PATCHES_DIR"/*.yaml "$PATCHES_DIR"/*.yml; do
      [[ -f "$f" ]] && files+=("$f")
    done
  fi
  
  local errors=0
  for f in "${files[@]}"; do
    [[ -f "$f" ]] || continue
    local id
    id="$(yaml_get "$f" "id")"
    
    if [[ -z "$id" ]]; then
      warn "$f: missing 'id'"
      errors=$((errors + 1))
      continue
    fi
    
    local created
    created="$(yaml_get "$f" "created")"
    if [[ -z "$created" ]]; then
      warn "$f: missing 'created'"
      errors=$((errors + 1))
    fi
    
    # Check that referenced files exist
    local tmp_dir
    tmp_dir="$(mktemp -d)"
    parse_steps "$f" "$tmp_dir" > /dev/null
    
    for step in "$tmp_dir"/step-*.yaml; do
      [[ -f "$step" ]] || continue
      local stype
      stype="$(yaml_get "$step" "type")"
      
      case "$stype" in
        file)
          local cf
          cf="$(yaml_get "$step" "content_file")"
          if [[ -n "$cf" && ! -f "$FILES_DIR/$cf" ]]; then
            warn "$id: content_file not found: files/$cf"
            errors=$((errors + 1))
          fi
          ;;
        config_patch)
          local mf
          mf="$(yaml_get "$step" "merge_file")"
          if [[ -n "$mf" && ! -f "$FILES_DIR/$mf" ]]; then
            warn "$id: merge_file not found: files/$mf"
            errors=$((errors + 1))
          fi
          ;;
        skill)
          local sn sd
          sn="$(yaml_get "$step" "name")"
          sd="$(yaml_get "$step" "source_dir")"
          local sp="${SKILLS_DIR}/${sd:-$sn}"
          if [[ -n "$sn" && ! -d "$sp" ]]; then
            warn "$id: skill directory not found: skills/${sd:-$sn}"
            errors=$((errors + 1))
          fi
          ;;
      esac
    done
    
    rm -rf "$tmp_dir"
    ok "$id"
  done
  
  if [[ $errors -gt 0 ]]; then
    die "Validation failed with $errors error(s)"
  fi
  ok "All patches valid"
}

cmd_publish() {
  cmd_validate
  
  cd "$REPO_ROOT"
  git add -A
  
  if git diff --cached --quiet; then
    info "Nothing to publish (no changes)"
    return 0
  fi
  
  # Build commit message from new/changed patches
  local msg="Publish patches:"
  for f in $(git diff --cached --name-only | grep -E '^patches/'); do
    local id
    id="$(basename "$f" .yaml)"
    id="$(basename "$id" .yml)"
    msg="$msg $id"
  done
  
  git commit -m "$msg"
  git push
  ok "Published to remote"
}

cmd_pull() {
  cd "$REPO_ROOT"
  git pull --ff-only
  ok "Pulled latest patches"
}

cmd_apply() {
  local deployment=""
  local dry_run=false
  
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --deployment|-d) shift; deployment="$1" ;;
      --dry-run)       dry_run=true ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done
  
  [[ -z "$deployment" ]] && die "Usage: openclaw-patch apply --deployment <name>"
  
  init_state
  
  local applied=0
  local skipped=0
  local failed=0
  
  while IFS= read -r patch_file; do
    [[ -f "$patch_file" ]] || continue
    
    local id desc
    id="$(yaml_get "$patch_file" "id")"
    desc="$(yaml_get "$patch_file" "description")"
    
    # Skip already applied
    if is_applied "$id"; then
      skipped=$((skipped + 1))
      continue
    fi
    
    # Check target match
    local targets_raw
    targets_raw="$(yaml_get_targets "$patch_file")"
    read -ra targets <<< "$targets_raw"
    
    if ! matches_target "$deployment" "${targets[@]}"; then
      continue
    fi
    
    if $dry_run; then
      info "[DRY RUN] Would apply: $id — $desc"
      applied=$((applied + 1))
      continue
    fi
    
    info "Applying: $id — $desc"
    
    # Parse and execute steps
    local tmp_dir
    tmp_dir="$(mktemp -d)"
    local step_count
    step_count="$(parse_steps "$patch_file" "$tmp_dir")"
    
    local step_failed=false
    for step_file in "$tmp_dir"/step-*.yaml; do
      [[ -f "$step_file" ]] || continue
      if ! exec_step "$step_file"; then
        warn "Step failed in patch $id"
        step_failed=true
        break
      fi
    done
    
    rm -rf "$tmp_dir"
    
    if $step_failed; then
      warn "Patch $id failed — stopping"
      failed=$((failed + 1))
      break
    fi
    
    mark_applied "$id"
    applied=$((applied + 1))
    ok "Applied: $id"
    
  done < <(get_sorted_patches)
  
  echo ""
  echo "Summary: $applied applied, $skipped already applied, $failed failed"
}

cmd_status() {
  local deployment=""
  
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --deployment|-d) shift; deployment="$1" ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done
  
  [[ -z "$deployment" ]] && die "Usage: openclaw-patch status --deployment <name>"
  
  init_state
  
  echo "Patch status for deployment: $deployment"
  echo ""
  
  local pending=0
  local applied=0
  
  while IFS= read -r patch_file; do
    [[ -f "$patch_file" ]] || continue
    
    local id desc
    id="$(yaml_get "$patch_file" "id")"
    desc="$(yaml_get "$patch_file" "description")"
    
    # Check target match
    local targets_raw
    targets_raw="$(yaml_get_targets "$patch_file")"
    read -ra targets <<< "$targets_raw"
    
    if ! matches_target "$deployment" "${targets[@]}"; then
      continue
    fi
    
    if is_applied "$id"; then
      printf "  ✓ %-30s %s\n" "$id" "$desc"
      applied=$((applied + 1))
    else
      printf "  ○ %-30s %s\n" "$id" "$desc"
      pending=$((pending + 1))
    fi
  done < <(get_sorted_patches)
  
  echo ""
  echo "  $applied applied, $pending pending"
}

cmd_sync() {
  cmd_pull
  cmd_apply "$@"
}

cmd_diff() {
  cmd_apply --dry-run "$@"
}

# ── Main ──────────────────────────────────────────────────────────────────────

cmd="${1:-help}"
shift || true

case "$cmd" in
  new)      cmd_new "$@" ;;
  list|ls)  cmd_list ;;
  validate) cmd_validate "$@" ;;
  publish)  cmd_publish ;;
  pull)     cmd_pull ;;
  apply)    cmd_apply "$@" ;;
  status)   cmd_status "$@" ;;
  sync)     cmd_sync "$@" ;;
  diff)     cmd_diff "$@" ;;
  version)  echo "openclaw-patch v$VERSION" ;;
  help|--help|-h)
    echo "openclaw-patch v$VERSION — Declarative patch system for OpenClaw"
    echo ""
    echo "Commands:"
    echo "  new <name>                    Create a new patch scaffold"
    echo "  list                          List all patches"
    echo "  validate [name]               Validate patch manifests"
    echo "  publish                       Validate, commit, and push"
    echo "  pull                          Git pull latest patches"
    echo "  apply -d <deployment>         Apply pending patches"
    echo "  status -d <deployment>        Show applied/pending patches"
    echo "  sync -d <deployment>          Pull + apply in one shot"
    echo "  diff -d <deployment>          Show what would change (dry run)"
    echo ""
    echo "Options:"
    echo "  --deployment, -d <name>       Deployment name (e.g. opensesame, mac-mini)"
    echo "  --dry-run                     Show what would happen without doing it"
    echo ""
    echo "Environment:"
    echo "  OPENCLAW_PATCHES_DIR          Override repo root"
    echo "  OPENCLAW_HOME                 Override OpenClaw home (~/.openclaw)"
    ;;
  *) die "Unknown command: $cmd (try 'openclaw-patch help')" ;;
esac
