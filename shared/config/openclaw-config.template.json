{
  "_comment": "OpenClaw configuration template. Matches a fresh 'openclaw onboard' output plus channel placeholders. Apply patches from shared/patches/ to layer on features. Save secrets in ~/.openclaw/.env (gitignored), NOT in env.vars.",

  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },

  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },

  "messages": {
    "ackReactionScope": "group-mentions"
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },

  "session": {
    "dmScope": "per-channel-peer"
  },

  "channels": {
    "_comment_discord": "Get token from https://discord.com/developers/applications",
    "discord": {
      "enabled": true,
      "token": "${DISCORD_TOKEN}",
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "YOUR_DISCORD_USER_ID"
      ],
      "guilds": {
        "YOUR_GUILD_ID": {
          "requireMention": false
        }
      }
    },
    "_comment_telegram": "Get bot token from @BotFather on Telegram",
    "telegram": {
      "enabled": false,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "groupPolicy": "allowlist",
      "allowFrom": [],
      "groups": {}
    },
    "_comment_slack": "See https://docs.openclaw.ai/channels/slack for setup",
    "slack": {
      "enabled": false,
      "mode": "socket",
      "appToken": "${SLACK_APP_TOKEN}",
      "botToken": "${SLACK_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "groupPolicy": "allowlist",
      "allowFrom": [],
      "channels": {}
    }
  },

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": ""
    },
    "tailscale": {
      "mode": "off"
    }
  }
}
